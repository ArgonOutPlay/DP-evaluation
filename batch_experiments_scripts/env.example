# Environment variables used by scripts in batch_experiments_scripts
# NOTE: run_batch_inference.py loads semant_demo.config, which reads these env vars.

# OpenAI credentials / endpoint
OPENAI_API_KEY=
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Models
OPENAI_MODEL=gpt-4o-mini
OPENAI_EVAL_MODEL=gpt-4o-mini
GOOGLE_MODEL=gemini-2.5-pro
OLLAMA_MODEL=gemma3:12b
OLLAMA_URLS=http://localhost:11434

# API keys for other services
GOOGLE_API_KEY=
LANGCHAIN_API_KEY=

# Weaviate / embedding service
WEAVIATE_HOST=localhost
WEAVIATE_REST_PORT=8080
WEAVIATE_GRPC_PORT=50051
EMBEDDING_SERVICE_HOST=embedding-service
EMBEDDING_SERVICE_PORT=8001

# Runtime / app settings
MODEL_TEMPERATURE=0.0
RAG_CONFIGS_PATH=./rag_configs
SEARCH_SUMMARIZER_CONFIG=./configs/search_summarizer.yaml

# Optional app settings (not required for basic batch scripts unless your semant_demo config uses them)
PRODUCTION=false
PORT=8000
STATIC_PATH=./static
ALLOWED_ORIGIN=http://localhost:9000
FEEDBACK_WEBHOOK_URL=
FEEDBACK_LOG_PATH=./feedback.log.jsonl
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_SECRET
TOPICER_URL=http://localhost:8089
TOPICER_CONFIG_NAME=openai
TOPICER_TIMEOUT=600.0
SPAN_CHAT_API_KEY=
SPAN_CHAT_API_URL=
SPAN_CHAT_MODEL=
SPAN_CHAT_TEMPERATURE=0.4
SPAN_CHAT_MAX_TOKENS=1024
SPAN_CHAT_CONTEXT_CHARS=1500
SPAN_CHAT_HISTORY_LIMIT=20
